# Convex — set automatically by `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Claude API — used in Convex actions only (Phase 2)
ANTHROPIC_API_KEY=

# Voyage AI — embeddings for The Brain (BNH-10). Model: voyage-3-large (1024d).
# Anthropic's recommended embedder for domain text. See convex/ai/brain/embeddings.ts.
VOYAGE_API_KEY=

# The Brain — "1" enables Anthropic Contextual Retrieval on ingest (recommended
# for production quality; leave blank for a cheap first bring-up).
BRAIN_CONTEXTUAL=

# BNH-10 P2: set to 1 to use the streaming @convex-dev/agent chat (parallel-run)
NEXT_PUBLIC_AGENT_CHAT=
